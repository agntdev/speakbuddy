[
  {
    "name": "Start Guided Exercise (no profile yet)",
    "steps": [
      {
        "send": { "callback": "guided:start" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "You haven't set up your profile yet! Tap /start to begin."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "guided exercise with profile",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [
          { "method": "sendMessage" }
        ]
      },
      {
        "send": { "callback": "onboard:level:beginner" },
        "expect": [
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "onboard:topics:done" },
        "expect": [
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "guided:start" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Pick a topic for your guided exercise:" } }
        ]
      }
    ]
  }
]
